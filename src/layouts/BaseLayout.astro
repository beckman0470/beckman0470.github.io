---
import '../styles/global.css';

const { title = 'Chicken Dad Lab｜雞爸爸生活實驗室', description = '用科學理解健康，用陪伴記錄成長。' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <div class="container nav">
        <a class="logo" href="/">🐔 Chicken Dad Lab</a>
        <nav>
          <a href="/#posts">文章</a>
          <a href="/#topics">分類</a>
          <a href="/#about">關於</a>
          <a href="/#contact">聯絡</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer>
      <div class="container">© 2026 Chicken Dad Lab｜雞爸爸生活實驗室</div>
    </footer>
  </body>
</html>
